<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.youflex.mapper.CommentReportMapper">

    <resultMap id="commentReportResultMap" type="com.youflex.dto.CommentReportDTO">
        <id property="commentReportId" column="comment_report_id" />
        <result property="commentId" column="comment_id" />
        <result property="memberId" column="member_id" />
        <result property="commentReportReason" column="comment_report_reason" />
        <result property="commentReportStatus" column="comment_report_status" />
        <result property="commentReportCreatedAt" column="comment_report_created_at" />
        <result property="commentReportContent" column="comment_report_content" />
        <result property="memberName" column="reporter_name" />
        <result property="commentContent" column="comment_content" />
        <result property="reportedMemberId" column="reported_member_id" />
        <result property="reportedMemberName" column="reported_member_name" />
    </resultMap>

    <select id="selectCommentReportList" resultMap="commentReportResultMap">
        SELECT cr.comment_report_id, cr.comment_id, cr.member_id, cr.comment_report_reason, cr.comment_report_status,
               cr.comment_report_created_at, cr.comment_report_content,
               reporter.member_name AS reporter_name,
               c.comment_content,
               c.member_id AS reported_member_id,
               author.member_name AS reported_member_name
        FROM comment_report cr
        JOIN member reporter ON cr.member_id = reporter.member_id
        JOIN comment c ON cr.comment_id = c.comment_id
        JOIN member author ON c.member_id = author.member_id
        ORDER BY cr.comment_report_created_at DESC
    </select>

    <update id="updateCommentReportStatus">
        UPDATE comment_report
        SET comment_report_status = #{commentReportStatus}
        WHERE comment_report_id = #{commentReportId}
    </update>

    <!-- 처리완료 탭 - 신고 기록 자체 완전 삭제(원본 댓글과는 무관) -->
    <delete id="deleteCommentReport" parameterType="int">
        DELETE FROM comment_report
        WHERE comment_report_id = #{commentReportId}
    </delete>

</mapper>
